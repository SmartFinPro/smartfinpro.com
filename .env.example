# ============================================================
# SmartFinPro Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ===================
# SUPABASE (Required)
# ===================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===================
# SITE CONFIG
# ===================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SmartFinPro

# ===================
# ANALYTICS (Optional)
# ===================
# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=smartfinpro.com

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===================
# EMAIL (Resend)
# ===================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=hello@smartfinpro.com

# ===================
# AFFILIATE NETWORKS
# ===================
# Awin API (UK)
AWIN_API_TOKEN=your-awin-token
AWIN_PUBLISHER_ID=your-publisher-id

# CJ Affiliate
CJ_API_KEY=your-cj-api-key
CJ_WEBSITE_ID=your-website-id

# PartnerStack
PARTNERSTACK_API_KEY=your-partnerstack-key
PARTNERSTACK_SECRET=your-partnerstack-secret

# FinanceAds
FINANCEADS_API_KEY=your-financeads-key

# ===================
# SEO / RANKING (Optional)
# ===================
# Google Search Console Service Account
GSC_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GSC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----
GSC_SITE_URL=https://smartfinpro.com

# Serper.dev (Live SERP Pulse)
# Get from: https://serper.dev/api-key
SERPER_API_KEY=your-serper-api-key

# Anthropic API (Content Generation)
ANTHROPIC_API_KEY=sk-ant-api-xxxxxxxx

# Google Indexing API (Instant Index — Genesis Hub)
# Service Account JSON for urlNotifications.publish (URL_UPDATED)
# 1. Create service account at: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Enable the "Web Search Indexing API" in your GCP project
# 3. Add service account as Owner in Google Search Console
# 4. Paste the raw JSON key file content as the value (or base64-encode it)
GOOGLE_INDEXING_JSON=

# ===================
# DEPLOY HOOK (Optional)
# ===================
# POST webhook URL to trigger a rebuild (Cloudways, Vercel, Netlify, etc.)
# Used by Freshness Boost to rebuild static pages after content_overrides update
DEPLOY_HOOK_URL=https://your-hosting-provider.com/deploy-hook/your-secret

# ===================
# GEOLOCATION (Optional)
# ===================
# IP Geolocation service
IPINFO_TOKEN=your-ipinfo-token

# ===================
# TELEGRAM (Alerts + AI Strategy Digest)
# ===================
# Create bot via @BotFather, get chat ID via @userinfobot or getUpdates API
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890

# Webhook setup (run once):
# curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#   -H "Content-Type: application/json" \
#   -d '{"url": "https://smartfinpro.com/api/telegram/webhook?secret=<CRON_SECRET>"}'

# ===================
# CRON JOBS
# ===================
# Secret for securing cron endpoints
CRON_SECRET=your-random-secret-string

# Cron schedule (add to crontab):
# */15 * * * * curl -sf -H "Authorization: Bearer $CRON_SECRET" https://smartfinpro.com/api/cron/spike-monitor
# 0 20 * * *  curl -sf -H "Authorization: Bearer $CRON_SECRET" https://smartfinpro.com/api/cron/daily-strategy

# ===================
# SECURITY (Round-2 Audit 2026-04-17)
# ===================
# Resend webhook signature secret — MANDATORY in production, otherwise
# /api/webhooks/resend returns 503 (no silent bypass). Obtain from Resend
# Dashboard → Webhooks → Signing Secret.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Internal health endpoint token (separate from CRON_SECRET so blast radius
# of a leak stays contained). Any random 32+ char string.
HEALTH_TOKEN=your-random-health-token

# Optional: CSP report-uri endpoint (F-17). If set, violations are reported
# here. Point at Sentry/report-uri.com/your own collector. Leave unset to
# omit the directive.
CSP_REPORT_URI=

# Optional: Enable CSP upgrade-insecure-requests directive. Set to "1" to force
# browsers to upgrade any http:// subresource to https://. Leave unset in dev.
ENABLE_CSP_UPGRADE=

# ===================
# SENTRY (Observability)
# ===================
# Sentry auth token for source-map upload during build. Only needed in CI.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=smartfinpro
SENTRY_PROJECT=smartfinpro-web

# ===================
# FEATURE FLAGS
# ===================
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true
