{
  "permissions": {
    "allow": [
      "mcp__smartfinpro__list_affiliate_links",
      "mcp__smartfinpro__get_revenue_stats",
      "mcp__smartfinpro__get_conversion_funnel",
      "mcp__smartfinpro__get_content_health",
      "mcp__smartfinpro__detect_schema_drift",
      "mcp__smartfinpro__get_orphan_slugs"
    ],
    "deny": [
      "Bash(rm*app/(dashboard)*)",
      "Bash(rm*app/\\(dashboard\\)*)",
      "Bash(rm*components/dashboard*)",
      "Bash(rm*supabase/migrations*)",
      "Bash(rm*lib/supabase*)",
      "Bash(rm*lib/actions*)",
      "Bash(rm*app/api/cron*)",
      "Bash(rm*app/api/genesis*)",
      "Bash(rm*app/api/track*)",
      "Bash(rm*app/api/webhooks*)",
      "Bash(rm*scripts/seo-baseline*)",
      "Bash(rm*scripts/check-seo-quality*)",
      "Bash(rimraf*dashboard*)",
      "Bash(rimraf*supabase*)",
      "Bash(rimraf*lib/actions*)",
      "Bash(rimraf*app/api*)",
      "Bash(git rm*app/(dashboard)*)",
      "Bash(git rm*components/dashboard*)",
      "Bash(git rm*supabase/migrations*)",
      "Bash(git rm*lib/actions*)",
      "Bash(git rm -r*dashboard*)",
      "Bash(git rm -r*supabase*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"${file}\"; if echo \"$FILE\" | grep -qE '\\.(ts|tsx)$' && echo \"$FILE\" | grep -qE '(^|/)(app|components|lib)/'; then /opt/homebrew/bin/node scripts/check-client-server-imports-fast.mjs \"$FILE\" 2>&1 | head -8 || true; fi"
          }
        ]
      }
    ]
  }
}
