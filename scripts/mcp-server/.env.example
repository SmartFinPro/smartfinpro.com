# SmartFinPro MCP Server — Environment Variables
#
# The server loads ../../.env.local at startup (via dotenv).
# This file is DOCUMENTATION ONLY — the actual values live in the
# repo-root .env.local (gitignored). Do NOT create a separate .env here.
#
# Required (same values as Next.js app uses):
#   NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
#   SUPABASE_SERVICE_KEY=eyJ...
#
# Optional:
#   SFP_CONTENT_ROOT=./content   # Default content-walker root for get_orphan_slugs
