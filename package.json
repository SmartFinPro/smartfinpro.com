{
  "name": "smartfinpro.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next/dev/lock && (lsof -ti:${PORT:-3000} 2>/dev/null | xargs kill -9 2>/dev/null || true)",
    "dev": "next dev",
    "dev:clean": "bash bin/fix-cache.sh --restart",
    "build": "next build",
    "postbuild": "node scripts/inject-critical-css.mjs",
    "build:prod": "next build && node scripts/inject-critical-css.mjs",
    "stress-test": "k6 run scripts/stress-test.js",
    "stress-test:smoke": "k6 run --vus 10 --duration 30s scripts/stress-test.js",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "prod": "npm run build && pm2 start ecosystem.config.js --env production",
    "reload": "pm2 reload SmartFinPro-Live --update-env",
    "stop": "pm2 stop SmartFinPro-Live",
    "logs": "pm2 logs SmartFinPro-Live --lines 100",
    "health": "curl -sf http://localhost:${PORT:-3000}/ > /dev/null && echo 'OK' || echo 'FAIL'",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-email/components": "^1.0.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 4 versions",
    "not dead",
    "Safari >= 14",
    "iOS >= 14",
    "Firefox >= 78",
    "Chrome >= 80"
  ],
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
